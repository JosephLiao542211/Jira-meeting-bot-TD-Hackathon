# ── Recall.ai ──────────────────────────────────────────────────────────────────
RECALL_API_KEY=Token your_recall_api_key_here
RECALL_REGION=us-west-2
BOT_NAME=Jira Assistant

# Public WSS URL that Recall.ai will connect to (use ngrok for local dev)
# e.g. wss://abc123.ngrok.io/ws/recall
PUBLIC_WS_URL=wss://your-server.com/ws/recall


# ── Gemini ────────────────────────────────────────────────────
GEMINI_API_KEY=sk-ant-...

# ── Jira ───────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=ENG

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
